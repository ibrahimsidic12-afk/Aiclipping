{
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "DATABASE_URL",
    "DIRECT_DATABASE_URL",
    "DATABASE_POOL_SIZE",
    "REGOLO_API_KEY",
    "REGOLO_BASE_URL",
    "REDIS_URL",
    "S3_BUCKET",
    "S3_REGION",
    "S3_ENDPOINT",
    "S3_PROVIDER",
    "S3_ACCESS_KEY",
    "S3_SECRET_KEY",
    "S3_PUBLIC_URL",
    "JWT_SECRET",
    "MAX_FILE_SIZE_MB",
    "MAX_VIDEO_DURATION_SECONDS",
    "CONCURRENT_WORKERS",
    "NODE_ENV",
    "NEXT_PUBLIC_APP_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
